// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkOrder {
  id           String    @id
  type         String
  siteType     String
  region       String
  title        String
  location     String
  partner      String
  address      String
  lat          Float
  lng          Float
  status       String
  contractor   String?
  assignedTech String?
  equipment    String    // Stored as JSON string
  task         String
  mopItems     String    // Stored as JSON string
  hours        Int
  travelHours  Int
  apEngineer   String
  apPhone      String
  created      DateTime  @default(now())
  completedAt  DateTime?

  // Relations
  photos       Photo[]
  workReport   WorkReport?
}

model Photo {
  id          String   @id @default(cuid())
  orderId     String
  key         String   // The photo checklist key
  lat         String
  lng         String
  url         String
  timestamp   String

  order       WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, key])
}

model WorkReport {
  id          String   @id @default(cuid())
  orderId     String   @unique
  arrival     String
  departure   String
  notes       String
  details     String
  engineer    String
  numTechs    Int

  order       WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Technician {
  id         String @id
  name       String
  specialty  String
  zone       String
  contractor String
  status     String
  orders     Int
  lat        Float
  lng        Float
}
